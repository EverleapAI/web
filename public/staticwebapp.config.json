{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.{css,js,png,jpg,svg,mp4,webm,ico}"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".mp4": "video/mp4"
  },
  "routes": [
    {
      "route": "/",
      "redirect": "/login",
      "statusCode": 302,
      "headers": { "cache-control": "no-store" }
    },
    {
      "route": "/welcome",
      "redirect": "/login",
      "statusCode": 302,
      "headers": { "cache-control": "no-store" }
    },
    {
      "route": "/video/*",
      "headers": { "cache-control": "public, max-age=604800, immutable" }
    }
  ]
}
